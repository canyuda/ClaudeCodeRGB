{
  "env": {
    "CLAUDE_RGB_HOST": "192.168.2.95",
    "CLAUDE_RGB_MODE": "auto",
    "CLAUDE_RGB_LOG": "~/.claude/logs/rgb-wifi-hook.log"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "python3 wifiClaudeCodeRGB/claude_rgb_wifi_hook.py",
            "async": true,
            "timeout": 2
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 wifiClaudeCodeRGB/claude_rgb_wifi_hook.py",
            "async": true,
            "timeout": 2
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 wifiClaudeCodeRGB/claude_rgb_wifi_hook.py",
            "async": true,
            "timeout": 2
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
