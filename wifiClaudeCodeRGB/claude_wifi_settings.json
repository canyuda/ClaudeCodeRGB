{
  "env": {
    "CLAUDE_RGB_HOST": "非必需, 默认为claude-rgb.local",
    "CLAUDE_RGB_MODE": "auto",
    "CLAUDE_RGB_LOG": "非必需，默认不写日志"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/claude_rgb_wifi_hook.py",
            "async": true,
            "timeout": 2
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/claude_rgb_wifi_hook.py",
            "async": true,
            "timeout": 2
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/claude_rgb_wifi_hook.py",
            "async": true,
            "timeout": 2
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/claude_rgb_wifi_hook.py",
            "async": true,
            "timeout": 2
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/claude_rgb_wifi_hook.py",
            "async": true,
            "timeout": 2
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/claude_rgb_wifi_hook.py",
            "async": true,
            "timeout": 2
          }
        ]
      }
    ],
    "PermissionDenied": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/claude_rgb_wifi_hook.py",
            "async": true,
            "timeout": 2
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/claude_rgb_wifi_hook.py",
            "async": true,
            "timeout": 2
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/claude_rgb_wifi_hook.py",
            "async": true,
            "timeout": 2
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/claude_rgb_wifi_hook.py",
            "async": true,
            "timeout": 2
          }
        ]
      }
    ]
  }
}
